# Supabase (Vite exposes only VITE_* to the browser)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_key"

# Production: set to your canonical origin (pick ONE: www or apex). Used for OAuth/magic-link callback URLs.
# Must match Supabase → Authentication → URL Configuration (Site URL + Redirect URLs) and Google OAuth JS origins.
# VITE_SITE_URL="https://bluprntai.com"

# Stripe Checkout (Upgrade modal) — Price IDs from Stripe Dashboard → Products
# VITE_STRIPE_ARCHITECT_PRICE_ID=price_...
# VITE_STRIPE_PROJECT_PASS_PRICE_ID=price_...

# Gemini (Edge Function secrets only — never expose in Vite)
# Supabase Dashboard → Edge Functions → Secrets:
#   GEMINI_API_KEY   — required for invoice OCR (upload-invoice) and photo estimates (photo-to-scope)
#   GEMINI_MODEL     — optional; default gemini-2.5-flash (see docs/gemini-api.md and https://ai.google.dev/gemini-api/docs/models )

# Stripe webhook (Edge Function secrets, not VITE_*):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_ARCHITECT_PRICE_ID=price_...  (required on Edge for create-checkout: subscription vs one-time mode)

# Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets):
# ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW_MS=60000
