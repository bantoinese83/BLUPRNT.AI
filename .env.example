# Supabase (Vite exposes only VITE_* to the browser)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="your_anon_key"

# Production site origin for Google OAuth + magic links (defaults to current origin in dev)
# VITE_SITE_URL="https://your-domain.com"

# Optional: client-side Gemini
# GEMINI_API_KEY=

# Invoice OCR (Edge Function secret): Set GEMINI_API_KEY in Supabase Dashboard → Edge Functions → Secrets
# When set, invoice PDFs are parsed with Gemini Vision for vendor, line items, totals.

# Stripe — Payment link URLs from Stripe Dashboard → Products → Add payment link
# When set: Upgrade modal shows checkout buttons. When unset: shows "Coming soon"
# Project Pass: add parameter "project_id" in Stripe Dashboard so ?project_id=xxx works
VITE_STRIPE_ARCHITECT_URL=
VITE_STRIPE_PROJECT_PASS_URL=

# Stripe webhook (Edge Function secrets, not VITE_*):
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets):
# ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW_MS=60000
